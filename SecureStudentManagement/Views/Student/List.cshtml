@model SecureStudentManagement.Models.PagedLearnerViewModel

@{
    ViewData["Title"] = "Learner Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-wrapper {
        width: 100%;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1f1b2e;
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: #6b7280;
        line-height: 1.7;
    }

    .add-btn {
        background: linear-gradient(135deg, #4c1d95, #7c3aed);
        color: white;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 10px 20px rgba(76, 29, 149, 0.12);
        transition: 0.2s;
    }

        .add-btn:hover {
            transform: translateY(-1px);
        }

    .filter-card {
        background: #ffffff;
        border: 1px solid #ede9fe;
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 30px;
    }

    .filter-row {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .custom-input {
        flex: 1;
        min-width: 280px;
        padding: 14px 16px;
        border: 1px solid #ddd6fe;
        border-radius: 14px;
        outline: none;
        font-size: 0.95rem;
        background: #fafafa;
    }

        .custom-input:focus {
            border-color: #7c3aed;
            background: white;
        }

    .learner-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
    }

    .learner-card {
        background: white;
        border: 1px solid #ede9fe;
        border-radius: 22px;
        padding: 24px;
        transition: 0.2s;
        box-shadow: 0 10px 25px rgba(0,0,0,0.02);
    }

        .learner-card:hover {
            transform: translateY(-2px);
        }

    .student-top {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .student-image {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        object-fit: cover;
        border: 2px solid #f3f4f6;
    }

    .student-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1f1b2e;
        margin-bottom: 5px;
    }

    .student-email {
        color: #6b7280;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .status-badge {
        display: inline-block;
        padding: 7px 14px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
        background: #f5f3ff;
        color: #4c1d95;
        margin-bottom: 18px;
    }

    .action-row {
        display: flex;
        gap: 10px;
    }

    .action-btn {
        flex: 1;
        text-align: center;
        padding: 11px;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
    }

    .view-btn {
        background: #f5f3ff;
        color: #4c1d95;
    }

    .edit-btn {
        background: #ede9fe;
        color: #5b21b6;
    }

    .delete-btn {
        background: #fef2f2;
        color: #b91c1c;
    }

    .empty-box {
        background: white;
        border: 1px solid #ede9fe;
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        color: #6b7280;
    }
</style>

<div class="page-wrapper">

    <div class="page-header">

        <div>
            <div class="page-title">
                Learner Management
            </div>

            <div class="page-subtitle">
                Manage learner records, review academic profiles, and maintain secure student information.
            </div>
        </div>

        <a asp-action="Create" class="add-btn">
            Add New Learner
        </a>

    </div>

    <div class="filter-card">

        <div class="filter-row">

            <input type="text"
                   id="searchInput"
                   class="custom-input"
                   placeholder="Search learner by name or email"
                   oninput="filterResults()" />

            <select id="statusFilter"
                    class="custom-input"
                    onchange="filterResults()">

                <option value="All">All Status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>

            </select>

        </div>

    </div>

    @if (Model.Learners != null && Model.Learners.Any())
    {
        <div class="learner-grid" id="gridDisplay">

            @foreach (var student in Model.Learners)
            {
                <div class="learner-card"
                     data-status="@student.EnrolmentStatus"
                     data-name="@student.FirstName @student.LastName"
                     data-email="@student.Email">

                    <div class="student-top">

                        <img src="@(!string.IsNullOrEmpty(student.ProfileImageUrl) ? student.ProfileImageUrl : "https://via.placeholder.com/72")"
                             class="student-image" />

                        <div>
                            <div class="student-name">
                                @student.FirstName @student.LastName
                            </div>

                            <div class="student-email">
                                @student.Email
                            </div>
                        </div>

                    </div>

                    <div class="status-badge">
                        @student.EnrolmentStatus
                    </div>

                    <div class="action-row">

                        <a asp-action="Details"
                           asp-route-id="@student.id"
                           class="action-btn view-btn">
                            View
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@student.id"
                           class="action-btn edit-btn">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@student.id"
                           class="action-btn delete-btn">
                            Remove
                        </a>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">
            No learner records found.
        </div>
    }

</div>

@section Scripts {
    <script>
        function filterResults() {
            const status = document.getElementById("statusFilter").value.toLowerCase();
            const query = document.getElementById("searchInput").value.toLowerCase();
            const cards = document.querySelectorAll("[data-status]");

            cards.forEach(card => {
                const matchesStatus =
                    status === "all" ||
                    card.dataset.status.toLowerCase() === status;

                const matchesSearch =
                    card.dataset.name.toLowerCase().includes(query) ||
                    card.dataset.email.toLowerCase().includes(query);

                card.style.display =
                    (matchesStatus && matchesSearch) ? "block" : "none";
            });
        }
    </script>
}